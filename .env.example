# ===========================================
# TaskFlow 环境配置
# 复制此文件为 .env 并填入实际值
# ===========================================

# --- 必填 ---
# Supabase 项目 URL（格式：https://xxxxx.supabase.co）
VITE_SUPABASE_URL=your_supabase_url

# Supabase 匿名密钥（在 Supabase Dashboard → Project Settings → API 中获取）
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- 可选 ---
# DeepSeek API Key（AI 助手功能需要，不填则 AI 功能不可用）
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key